# Single n8n write webhook the frontend calls directly (no Python backend in prod).
# Copy to .env for local dev; set the same var in the Netlify dashboard
# (Site settings -> Environment variables) so it is baked at build time.
# Only VITE_-prefixed vars are exposed to the browser.
#
# The frontend picks the prize; n8n + the Google Sheets "Stock" tab are the source
# of truth for stock. On load the frontend POSTs { action: "stock" } here and gets
# back { stock: { ... } }. Each win POSTs { name, goodie_id, label } to append the
# guest + decrement stock; the webhook responds { result, goodie_id, remaining }.
# Leave blank to run in MOCK mode (no network: legend shows no counts, spins still work).

VITE_N8N_WRITE_URL=https://your-n8n-host/webhook/<id>

# CORS: the n8n Webhook node must allow this site's origin. Set the node's
# "Allowed Origins (CORS)" to your Netlify domain (or * while testing).

# n8n webhook URLs the frontend calls directly (no Python backend in prod).
# Copy to .env for local dev; set the same vars in the Netlify dashboard
# (Site settings -> Environment variables) so they are baked at build time.
# Only VITE_-prefixed vars are exposed to the browser.

VITE_N8N_CHECK_URL=https://your-n8n-host/webhook/lucky-draw-check
VITE_N8N_DRAW_URL=https://your-n8n-host/webhook/lucky-draw-draw
VITE_N8N_STOCK_URL=https://your-n8n-host/webhook/lucky-draw-stock

# CORS: each n8n Webhook node must allow this site's origin. Set the node's
# "Allowed Origins (CORS)" to your Netlify domain (or * while testing).

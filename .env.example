# n8n webhook URLs. Paste your two webhook URLs here.
# Leave BOTH blank to run in local MOCK mode (in-memory stock 30/30/30) for testing.

# READ webhook — returns current stock per goodie + claimed-name list.
N8N_READ_URL=

# WRITE webhook — appends one claim row {ts, name, label, goodie_id} to Excel.
N8N_WRITE_URL=
